    "\n",
    "import torch\n",
    "from torch import nn\n",
    "\n",
    "# Dummy data\n",
    "input_ids = torch.randint(0, 100, (2, 128))\n",
    "\n",
    "model = nn.Embedding(100, 32)\n",
    "output = model(input_ids)\n",
    "\n",
    "loss = output.mean()\n",
    "loss.backward()\n",
    "\n",
    "print(\"Loss:\", loss.item())\n"
   ]
